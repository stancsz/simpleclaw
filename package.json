{
  "name": "simpleclaw",
  "version": "0.1.0",
  "description": "High-performance, local-first autonomous agent workstation",
  "main": "electron/main.cjs",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.4.0",
    "@types/screenshot-desktop": "^1.15.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "chalk": "^5.3.0",
    "tsx": "^4.19.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "start": "bun run --allow-read=./workspace --allow-net=api.anthropic.com,mcp-gateway.internal --permission-deny-sys src/index.ts",
    "start:server": "bun run --allow-read=./workspace --allow-net=api.anthropic.com,mcp-gateway.internal --permission-deny-sys src/index.ts --mode=server",
    "start:hybrid": "bun run --allow-read=./workspace --allow-net=api.anthropic.com,mcp-gateway.internal --permission-deny-sys src/index.ts --mode=hybrid",
    "test": "bun test",
    "test:integration": "bun test src/core/integration.test.ts",
    "test:plugins": "./scripts/test-plugins.sh",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "npm run build:server && electron-builder",
    "build:server": "cd server && npm run build",
    "package:win": "electron-builder --win",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@google-cloud/functions-framework": "^5.0.2",
    "agent-browser": "^0.17.1",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "openai": "^6.32.0",
    "screenshot-desktop": "^1.15.3",
    "yaml": "^2.8.2"
  },
  "build": {
    "appId": "com.simpleclaw.app",
    "productName": "SimpleClaw",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "src/**/*",
      "cli/**/*",
      ".agents/**/*",
      "!**/node_modules/**/*",
      "!**/.next/**/*",
      "!**/dist/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "zip"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Development"
    }
  }
}
